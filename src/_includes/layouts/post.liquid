---
layout: layouts/sidebar.liquid
---

<div class="row">

  <!-- Contenu de l'article -->
  <div class="col-10 post">
    <div class="mb-4">
      <h1>{{ title }}</h1>
      <hr />
      {{ content }}
    </div>
  </div>

  <!-- Liens d'accès rapide au post -->
  <div class="col-2">
    <div class="mt-4 mb-4">
      {% render "mapTitles" %}
    </div>
  </div>

  <div class="col-12">
    <hr />
    <!-- <p class="text-muted" style="text-align: right; font-style: italic;">Document mis à jour le {{ date }}</p> -->
  </div>
</div>

<!-- Cartes de navigation (précédent et suivant) -->
{% assign pageUrl = page.url | remove_last: '/' %}
{% render "navigationButtons", list: docs_app.items, url: pageUrl %}